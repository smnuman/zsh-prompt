#!/usr/bin/env zsh
# =====================================================================
#  📦 PROMPT RUNTIME CONFIGURATION (./prompt-defaults)
# =====================================================================
#               DO NOT EDIT THIS FILE DIRECTLY
#  These are defaults for prompt behaviour, colours, icons, logic
#  The values are taken from this file unless overridden in:
#   •  ~/.config/zsh/prompt/prompt.rc
#  Modify ~/.config/zsh/prompt/prompt.rc to tweak values
# =====================================================================

PROMPT_MODE=${PROMPT_PLAIN:=0}      # 0=with bg, 1=plain mode (was PROMPT_PLAIN)

PROMPT_PATH_MODE=${PROMPT_PATH_DISPLAY_MODE:="smart:git"}   # Path display modes: full, short, smart, smart:git

PROMPT_CLR_MODE=${PROMPT_COLOR_MODE:="auto"}            # Available modes: light | dark | auto (auto detects terminal background color)

# # When running in a light terminal background
# COLOR_SCHEME_LIGHT=(
#   ROOT_COLOR="%K{15} %F{241}"
#   ROOT_PATH_COLOR="%K{195} %F{26}"
#   ROOT_PROMPT_COLOR=" %F{26}"
# )

# # When running in a dark terminal background
# COLOR_SCHEME_DARK=(
#   ROOT_COLOR="%K{15} %F{241}"
#   ROOT_PATH_COLOR="%K{39} %F{75}"
#   ROOT_PROMPT_COLOR=" %F{229}"
# )

# (( ${+PROMPT_LAYOUT_SEQUENCE} )) || PROMPT_LAYOUT_SEQUENCE=(time path git)
# PROMPT_LAYOUT=("${PROMPT_LAYOUT_SEQUENCE[@]}")
PROMPT_LAYOUT=("${(@)PROMPT_LAYOUT_SEQUENCE:=(time path git)}")

PROMPT_HL=${PROMPT_HIGHLIGHT:-path}    # Segment to highlight (default: path)
PROMPT_HL_ROOT_USER=${PROMPT_HIGHLIGHT_ROOT_USER:-1}       # Highlighting user segment, when user is root (1=yes, 0=no)

RPROMPT_SEGMENTS=${PROMPT_RIGHT_SEGMENTS:=1}    # right prompt segments enabled (1=yes, 0=no)
RPOMPT_LAYOUT=

# ------------------ Segment Toggles (admin use) -------------------------
PROMPT_OS_ICON="${PROMPT_SHOW_OS_ICON:=1}"                  # Show OS icon in prompt? (1 = show, 0 = hide)  
PROMPT_TIME="${PROMPT_SHOW_TIME:=1}"                        # Show time segment? (1 = show, 0 = hide)  
PROMPT_USER="${PROMPT_SHOW_USER:=1}"                        # Show user segment? (1 = show, 0 = hide)  
USER_WITH_MACHINE="${PROMPT_SHOW_USER_WITH_MACHINE:=0}"     # Show user@host (1) or just user (0)? (1 = show, 0 = hide)  
PROMPT_HISTORY_MODE="${PROMPT_SHOW_HISTORY_MODE:=1}"        # Show shared/private history icon? (1 = show, 0 = hide)  
PROMPT_NODE="${PROMPT_SHOW_NODE:=1}"                        # Show Node.js version? (1 = show, 0 = hide)  
PROMPT_VENV="${PROMPT_SHOW_VENV:=1}"                        # Show Python virtualenv name? (1 = show, 0 = hide)  
PROMPT_PATH="${PROMPT_SHOW_PATH:=1}"                        # Show current path? (1 = show, 0 = hide)  
PROMPT_GIT="${PROMPT_SHOW_GIT:=1}"                          # Show git info? (1 = show, 0 = hide)  
# --- Git Segment -----
SHOW_REMOTE="${PROMPT_GIT_SHOW_REMOTE:=1}"                  # Show remote name (1=show, 0=hide)
PRE_REMOTE="${PROMPT_GIT_PRE_REMOTE:=1}"                    # Remote before (1) or after (0) branch/status
# --- Time Format ------
PROMPT_TIME_FMT="${PROMPT_TIME_FORMAT:="%*"}"

PROMPT_HL_BG="${PROMPT_HIGHLIGHT_COLOR:=cyan}"
PROMPT_HL_FG="${PROMPT_HIGHLIGHT_TEXT:=white}"
PROMPT_normal_BG="${PROMPT_GENERAL_BODY:=15}"
PROMPT_normal_FG="${PROMPT_GENERAL_TEXT:=241}"
PROMPT_ROOT_BG="${PROMPT_GENERAL_ROOT_BODY:=red}"
PROMPT_ROOT_FG="${PROMPT_GENERAL_ROOT_TEXT:=15}"
PROMPT_ROOT_PreHL_BG="${PROMPT_ROOT_PreHL_BODY:=cyan}"
PROMPT_ROOT_PreHL_FG="${PROMPT_ROOT_PreHL_TEXT:=15}"
PROMPT_EL_FG="${PROMPT_ELEMENT_COLOR:=black}"
PROMPT_OS_ROOT_BG="${PROMPT_OS_ROOT_BODY:=cyan}"
PROMPT_OS_ROOT_FG="${PROMPT_OS_ROOT_COLOR:=red}"
PROMPT_OS_FG="${PROMPT_OS_COLOR:=blue}"
PROMPT_PROMPT_FG="${PROMPT_PROMPT_COLOR:=yellow}"

_VS_GIT_BG="$PROMPT_HL_BG"

# ----------------------- Icons --------------------------------------
# Override OS icon for fun
CUSTOM_OS="${CUSTOM_OS_ICON:="🐧"}"      # e.g., "" or "🐧"
# Override branch icon
CUSTOM_BRANCH="${CUSTOM_BRANCH_ICON:=""}"
# ----------------- Remote service icons ----------------------
ICON_GITHUB="\uF09B"
ICON_GITLAB="\uF296"

# --------------------- Colour Overrides ---------------------------
autoload -Uz colors && colors
typeset -gA fg

fg[orange]=208
fg[grey]=240
fg[pink]=205
fg[golden]=220
fg[gold]=214

GH_ICON_CLR="${GH_ICON_COLOR:=$fg[grey]}"
GL_ICON_CLR="${GL_ICON_COLOR:=$fg[orange]}"
GH_REMOTE_CLR="${GH_REMOTE_COLOR:=blue}"
GL_REMOTE_CLR="${GL_REMOTE_COLOR:=magenta}"
GIT_REMOTE_ACTIVE_CLR="${GIT_REMOTE_ACTIVE_COLOR:=yellow}"
GIT_REMOTE_PASSIVE_CLR="${GIT_REMOTE_PASSIVE_COLOR:=$fg[grey]}"

GIT_COLOR_GH="$fg[orange]"
GIT_COLOR_GL="$fg[gold]"

